[TEMPLATE]
# Empty = relative URLs (nginx reverse-proxies /api, /health, /ready → http://api:8000 inside docker-compose).
# Set to a full URL (e.g. https://api.example.com) to point the dev server at an external backend.
# Vite only exposes env vars prefixed with VITE_ to the client; keep that prefix or it will be undefined at runtime.
VITE_API_BASE_URL=
